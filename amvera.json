{
  "schemaVersion": 2,
  "build": {
    "type": "python",
    "requirements": "requirements.txt",
    "pythonVersion": "3.11"
  },
  "deploy": {
    "command": "gunicorn -k eventlet -w 1 -b 0.0.0.0:$PORT app:app",
    "env": {
      "PORT": "5000"
    },
    "healthcheck": {
      "path": "/",
      "timeout": 30
    }
  }
}